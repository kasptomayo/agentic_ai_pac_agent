        <mxCell id="frontend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D4E6F1;strokeColor=#3498DB;strokeWidth=2;" value="Frontend (React + Vite)" vertex="1">
          <mxGeometry height="80" width="400" x="400" y="220" as="geometry" />
        </mxCell>
        <mxCell id="frontend-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;verticalAlign=top;" value="• PdfUploader Component&#xa;• PDF Text Extraction (pdfjs-dist)&#xa;• React State Management&#xa;• Display REGO Output" vertex="1">
          <mxGeometry height="64" width="380" x="810" y="220" as="geometry" />
        </mxCell>
        <mxCell id="backend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5F4E6;strokeColor=#27AE60;strokeWidth=2;" value="Backend (Express.js + TypeScript)" vertex="1">
          <mxGeometry height="80" width="400" x="400" y="380" as="geometry" />
        </mxCell>
        <mxCell id="backend-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;verticalAlign=top;" value="• API Endpoint: POST /api/generate-rego&#xa;• CORS Configuration&#xa;• Request Validation&#xa;• Error Handling" vertex="1">
          <mxGeometry height="64" width="380" x="810" y="380" as="geometry" />
        </mxCell>
        <mxCell id="cloud" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCF3CF;strokeColor=#F39C12;strokeWidth=2;" value="Google ADK Agent (Cloud Run)" vertex="1">
          <mxGeometry height="80" width="400" x="400" y="540" as="geometry" />
        </mxCell>
        <mxCell id="cloud-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=11;align=left;verticalAlign=top;" value="• Endpoint: /run_sse&#xa;• Converts Bank Rules → OPA REGO&#xa;• Model: text-bison-001&#xa;• Secure HTTPS Communication" vertex="1">
          <mxGeometry height="64" width="380" x="810" y="548" as="geometry" />
        </mxCell>
        <mxCell id="config" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5B7B1;strokeColor=#E74C3C;strokeWidth=2;" value="Configuration (.env)" vertex="1">
          <mxGeometry height="80" width="200" x="50" y="380" as="geometry" />
