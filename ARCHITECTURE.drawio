        <mxCell id="config-text" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;align=left;verticalAlign=top;" value="• GOOGLE_ADK_API_KEY&#xa;• GOOGLE_ADK_API_URL&#xa;• GOOGLE_ADK_AGENT_ID&#xa;• PORT (4000)" vertex="1">
          <mxGeometry height="64" width="180" x="60" y="470" as="geometry" />
