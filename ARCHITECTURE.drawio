        <mxCell id="legend-title" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=12;fontStyle=1;align=left;" value="Technologies Used" vertex="1">
          <mxGeometry height="25" width="150" x="50" y="680" as="geometry" />
        </mxCell>
        <mxCell id="legend-tech" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=10;align=left;verticalAlign=top;" value="Frontend: React 18, TypeScript, Vite, pdfjs-dist, axios&#xa;Backend: Express.js, TypeScript, cors, dotenv, axios&#xa;External: Google ADK Agent, Cloud Run, OPA (Open Policy Agent)" vertex="1">
          <mxGeometry height="60" width="700" x="50" y="705" as="geometry" />
        </mxCell>
        <mxCell id="workflow" parent="1" style="text;html=1;strokeColor=none;fillColor=none;fontSize=9;align=center;italic=1;" value="Data Flow: 1. User uploads PDF → 2. Frontend extracts text → 3. Backend receives text → 4. Backend calls Google ADK Agent → 5. Agent converts rules to REGO → 6. REGO returned to Frontend → 7. Display to User" vertex="1">
